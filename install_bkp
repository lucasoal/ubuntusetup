#!/bin/bash

# ==============================================================================
# UBUNTU PRO SETUP - VERSÃO COMPLETA, RESILIENTE E HIERÁRQUICA
# ==============================================================================

set -uo pipefail

# --- Variáveis e Estética ---
YELLOW='\033[1;33m'
NC='\033[0m'
LOG_FILE="$HOME/setup_$(date +%F).log"
INDENT=""

# --- Funções de Controle e Log ---

log() {
    echo -e "${INDENT}${YELLOW}[$(date '+%H:%M:%S')] $1${NC}" | tee -a "$LOG_FILE"
}

try() {
    local OLD_INDENT_TRY="$INDENT"
    INDENT="$INDENT  "
    # Executa o comando diretamente ($@ preserva espaços e argumentos)
    if "$@"; then
        INDENT="$OLD_INDENT_TRY"
        return 0
    else
        log "⚠️  FALHA: $*. Continuando..."
        INDENT="$OLD_INDENT_TRY"
        return 1
    fi
}

push_indent() {
    OLD_INDENTS+=("$INDENT")
    INDENT="$INDENT  "
}

pop_indent() {
    INDENT="${OLD_INDENTS[-1]}"
    unset 'OLD_INDENTS[${#OLD_INDENTS[@]}-1]'
}
OLD_INDENTS=()


check_user_permissions() {
    # 1. Garante que o script ESTÁ sendo rodado como root/sudo
    if [[ $EUID -ne 0 ]]; then
        echo -e "${YELLOW}ERRO: Este script deve ser executado com sudo.${NC}"
        echo "Exemplo: sudo ./install"
        exit 1
    fi

    # 2. Identifica o usuário real (quem deu o sudo)
    # Se SUDO_USER estiver vazia, usamos o usuário logado (caso rode direto no root shell)
    REAL_USER=${SUDO_USER:-$(whoami)}
    REAL_HOME=$(getent passwd "$REAL_USER" | cut -d: -f6)

    log "Executando como root para o usuário: $REAL_USER"
    log "Diretório Home detectado: $REAL_HOME"
}

# --- Blocos de Instalação ---

# Função para substituir '/user/' pelo usuário atual
replace_user_template() {
    local file="./src/interface.dconf"
    # Determina o usuário atual (quem executa o sudo ou o usuário normal)
    local current_user="${SUDO_USER:-$(whoami)}"
    sed "s|/<USERNAME>/|/$current_user/|g" "$file" > "$file"
    echo "Substituição concluída: $file criado com o usuário $current_user"
}

install_system_pkgs() {
    log "Instalação de Pacotes APT"
    push_indent
    
    log "Atualizando repositórios..."
    try sudo apt update
    
    local pkgs=(build-essential curl flameshot git gnome-clocks gnome-weather gnome-tweaks gnome-shell-extension-manager htop jq make python3-pip python3-venv nodejs remmina software-properties-common tar unzip vim wget zip zsh tree)

    for p in "${pkgs[@]}"; do
        log "Instalando: $p"
        try sudo apt install -y "$p"
    done
    pop_indent
}

install_snaps() {
    log "Instalação de Snaps (com argumentos específicos)"
    push_indent
    
    # Lista de Snaps: "nome:argumentos" (deixe os argumentos vazios para padrão)
    local snaps=(
        "dbeaver-ce:--classic"
        "pyenv:--edge"
        "brave:"
        "discord:"
        "postman:"
    )

    for entry in "${snaps[@]}"; do
        local name="${entry%%:*}"
        local args="${entry#*:}"
        
        if [ -n "$args" ]; then
            log "Instalando: $name com $args"
            try sudo snap install "$name" $args
        else
            log "Instalando: $name (padrão)"
            try sudo snap install "$name"
        fi
    done
    pop_indent
}

install_external_debs() {
    log "Navegadores e IDEs (DEB)"
    push_indent
    local tmp_dir=$(mktemp -d)
    
    log "Baixando Google Chrome..."
    try wget -q -P "$tmp_dir" https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb
    
    log "Baixando VS Code..."
    try wget -q -O "$tmp_dir/vs-code.deb" "https://code.visualstudio.com/sha/download?build=stable&os=linux-deb-x64"
    
    log "Instalando arquivos baixados..."
    try sudo apt install -y "$tmp_dir"/*.deb
    rm -rf "$tmp_dir"
    pop_indent
}

setup_python() {
    log "Ambiente Python (PPA Deadsnakes)"
    push_indent
    try sudo add-apt-repository -y ppa:deadsnakes/ppa
    try sudo apt update
    local py_versions=(python3.10 python3.11 python3.12 python3.13)
    for v in "${py_versions[@]}"; do
        log "Instalando: $v"
        try sudo apt install -y "$v"
    done
    pop_indent
}

setup_cloudflare() {
    log "Cloudflare WARP (1.1.1.1)"
    push_indent
    try curl -fsSL https://pkg.cloudflareclient.com/pubkey.gpg | sudo gpg --dearmor -o /usr/share/keyrings/cloudflare-warp.gpg
    echo "deb [signed-by=/usr/share/keyrings/cloudflare-warp.gpg] https://pkg.cloudflareclient.com/ $(lsb_release -cs) main" | sudo tee /etc/apt/sources.list.d/cloudflare-client.list > /dev/null
    try sudo apt update
    try sudo apt install -y cloudflare-warp
    log "Registrando dispositivo..."
    try "yes | warp-cli registration new"
    pop_indent
}

setup_gnome_and_zsh() {
    log "Customização de Interface e Shell"
    push_indent

    # Verifica a pasta no HOME do usuário real
    if [ ! -d "$REAL_HOME/.oh-my-zsh" ]; then
        log "Instalando Oh My Zsh para $REAL_USER..."
        # Executa o instalador como o usuário real
        try sudo -u "$REAL_USER" sh -c "$(wget -O- https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended
        # Ajusta o tema no arquivo .zshrc do usuário real
        if [ -f "$REAL_HOME/.zshrc" ]; then
            log "Configurando tema bira..."
            try sed -i 's/^ZSH_THEME=.*/ZSH_THEME="bira"/' "$REAL_HOME/.zshrc"
            # Garante que o dono do arquivo continue sendo o usuário real
            chown "$REAL_USER:$REAL_USER" "$REAL_HOME/.zshrc"
        fi
    else
        log "Oh My Zsh já instalado para $REAL_USER."
    fi

    log "Definindo Zsh como shell padrão para $REAL_USER"
    # Localiza o caminho do binário do zsh
    local zsh_path=$(which zsh)
    if [ -n "$zsh_path" ]; then
        # Altera o shell do usuário real
        try chsh -s "$zsh_path" "$REAL_USER"
    else
        log "⚠️  ERRO: Zsh não encontrado. Instale-o antes de definir como padrão."
    fi

    log "Configurando Fontes e Atalhos..."
    if [ -f "./src/fonts/GoogleSans.ttf" ]; then
        mkdir -p "$HOME/.local/share/fonts"
        cp "./fonts/GoogleSans.ttf" "$HOME/.local/share/fonts/"
        fc-cache -f
        gsettings set org.gnome.desktop.interface font-name 'GoogleSans 12'
        gsettings set org.gnome.desktop.interface document-font-name 'GoogleSans 11'
        gsettings set org.gnome.desktop.interface monospace-font-name 'GoogleSansCode 12'
    fi
    pop_indent
}

setup_keybindings() {
    log "Customização de Atalhos de Teclado"
    push_indent

    # Atalhos de teclado (Exemplo Flameshot)
    local kb_path="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/"
    gsettings set org.gnome.settings-daemon.plugins.media-keys custom-keybindings "['$kb_path']"
    gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybindings:$kb_path name 'Flameshot'
    gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybindings:$kb_path command 'flameshot gui'
    gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybindings:$kb_path binding '<Super>Print'

    pop_indent
}

att_and_cleanup() {
    push_indent
    log "Atualizando o Sistema"
    try sudo apt update -y
    try sudo apt upgrade -y
    
    log "Limpeza de Sistema"
    try sudo apt autoremove -y
    try sudo apt autoclean -y
    pop_indent
}

remove_stock_games() {
    log "Removendo jogos nativos e pacotes relacionados"
    push_indent
    try sudo dpkg --configure -a
    
    log "Identificando pacotes..."
    # Lista pacotes, filtra por 'game', remove espaços e ignora bibliotecas críticas (opcional)
    local game_pkgs=$(dpkg --get-selections | grep -i "game" | awk '{print $1}' | xargs)
    
    if [ -n "$game_pkgs" ]; then
        log "Pacotes encontrados: $game_pkgs"
        try sudo apt purge -y $game_pkgs
        try sudo apt autoremove -y
    else
        log "Nenhum pacote de jogo encontrado."
    fi
    
    pop_indent
}

setup_gnome_dconf_style() {
    log "Configurações do GNOME (dconf)"
    push_indent
    
    replace_user_template
    
    # 1. Gerenciamento do Wallpaper
    local bg_url="https://wallpapercave.com/wp/wp10824773.jpg"
    local bg_dest="/usr/share/backgrounds/Catalina-4.jpg"

    log "Baixando background: $bg_url"

    mkdir -p "/usr/share/backgrounds"

    try curl -fL "$bg_url" -o "$bg_dest"

    try gsettings set org.gnome.desktop.background picture-uri "file://$bg_dest"
    try gsettings set org.gnome.desktop.background picture-uri-dark "file://$bg_dest"
    
    # 2. Instalação do cursor
    local cursor_zip="./src/icons/macOSCursorWhite.zip"
    local cursor_tmp="/tmp/macos_cursor"
    local cursor_dest="/usr/share/icons"
    
    if [ -f "$cursor_zip" ]; then
        log "Instalando cursor: $cursor_zip"
        
        rm -rf "$cursor_tmp"
        mkdir -p "$cursor_tmp"
        
        # Extrai o zip
        try unzip -o "$cursor_zip" -d "$cursor_tmp"
        
        # Move para /usr/share/icons
        try cp -r "$cursor_tmp"/* "$cursor_dest/"
        
        # Atualiza cache de ícones
        try gtk-update-icon-cache "$cursor_dest" || true
        
        # Define cursor no GNOME
        local cursor_name
        cursor_name=$(ls "$cursor_tmp" | head -n 1)
        
        if [ -n "$cursor_name" ]; then
            log "Aplicando cursor: $cursor_name"
            sudo -u "$REAL_USER" dbus-run-session gsettings set org.gnome.desktop.interface cursor-theme "$cursor_name"
        else
            log "⚠️  AVISO: Não foi possível detectar o nome do cursor."
        fi
    else
        log "⚠️  AVISO: Arquivo $cursor_zip não encontrado."
    fi
    
    # 3. Restauração do dconf
    local backup_file="./src/interface.dconf"
    if [ -f "$backup_file" ]; then
        log "Carregando backup dconf: $backup_file"
        sudo -u "$REAL_USER" dbus-run-session dconf load / < "$backup_file"
    else
        log "⚠️  AVISO: Arquivo $backup_file não encontrado."
    fi
    
    pop_indent
}

install_postgresql() {
    DB_USER="postgres"
    DB_PSSWD="postgres"
    DB_NAME="postgres"

    log "Você está prestes a instalar e configurar o PostgreSQL com:"
    push_indent

    log "Usuário '$DB_USER' • Senha '$DB_PSSWD' • Banco '$DB_NAME'"
    read -p "Deseja continuar? [Y/n] " CONFIRM

    if [[ "$CONFIRM" != "y" && "$CONFIRM" != "Y" ]]; then
    log "Cancelado."
    return 0
    fi

    log "Instalando PostgreSQL..."
    sudo apt install -y postgresql postgresql-contrib

    log "Iniciando serviço..."
    sudo systemctl start postgresql && sudo systemctl enable postgresql

    log "Criando usuário e banco..."
    sudo -i -u postgres psql <<EOF
DO
\$do\$
BEGIN
    CREATE USER $DB_USER WITH PASSWORD '$DB_PSSWD';
    CREATE DATABASE $DB_NAME OWNER $DB_USER;
    GRANT ALL PRIVILEGES ON DATABASE $DB_NAME TO $DB_USER;
END
\$do\$;

EOF
    log "Reiniciando PostgreSQL..."
    sudo systemctl restart postgresql

    log "Concluído! Banco '$DB_NAME' • Usuário '$DB_USER'"

    pop_indent
}


# --- Execução ---

main() {
    check_user_permissions

    log "INICIANDO SETUP DO AMBIENTE UBUNTU"
    
    # remove_stock_games
    # install_system_pkgs
    # install_snaps
    # install_external_debs
    # setup_python
    # setup_cloudflare
    setup_gnome_and_zsh
    # setup_keybindings
    setup_gnome_dconf_style
    # install_postgresql
    cleanup

    log "✅ PROCESSO FINALIZADO"
    
    read -p "Deseja reiniciar o sistema agora? [y/N] " resp
    [[ "$resp" =~ ^([yY][eE][sS]|[yY])$ ]] && sudo reboot
}

main "$@"