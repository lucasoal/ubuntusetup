#!/usr/bin/env bash

# ==============================================================================
# UBUNTU PRO SETUP — REMOTE INSTALLER READY
# curl -fsSL https://raw.githubusercontent.com/lucasoal/ubuntusetup/main/install | sudo bash
# ==============================================================================

set -Eeuo pipefail

# ==============================================================================
# CONFIG
# ==============================================================================

RAW_BASE="https://raw.githubusercontent.com/lucasoal/ubuntusetup/main"

LOG_FILE="/tmp/ubuntu-pro-setup-$(date +%F-%H%M%S).log"

export DEBIAN_FRONTEND=noninteractive

YELLOW='\033[1;33m'
GREEN='\033[1;32m'
RED='\033[1;31m'
NC='\033[0m'

INDENT=""
OLD_INDENTS=()

# ==============================================================================
# LOGGING
# ==============================================================================

log() {
    echo -e "${INDENT}${YELLOW}[$(date '+%H:%M:%S')] $1${NC}" | tee -a "$LOG_FILE"
}

success() {
    echo -e "${INDENT}${GREEN}[$(date '+%H:%M:%S')] $1${NC}" | tee -a "$LOG_FILE"
}

error() {
    echo -e "${INDENT}${RED}[$(date '+%H:%M:%S')] $1${NC}" | tee -a "$LOG_FILE"
}

push_indent() {
    OLD_INDENTS+=("$INDENT")
    INDENT="$INDENT  "
}

pop_indent() {
    INDENT="${OLD_INDENTS[-1]}"
    unset 'OLD_INDENTS[${#OLD_INDENTS[@]}-1]'
}

try() {
    local OLD_INDENT_TRY="$INDENT"

    INDENT="$INDENT  "

    if "$@"; then
        INDENT="$OLD_INDENT_TRY"
        return 0
    else
        error "FALHA: $*"
        INDENT="$OLD_INDENT_TRY"
        return 1
    fi
}

# ==============================================================================
# USER
# ==============================================================================

check_user_permissions() {

    if [[ $EUID -ne 0 ]]; then
        echo -e "${RED}Execute com sudo.${NC}"
        exit 1
    fi

    REAL_USER="${SUDO_USER:-root}"
    REAL_HOME="$(getent passwd "$REAL_USER" | cut -d: -f6)"

    log "Usuário detectado: $REAL_USER"
    log "Home detectada: $REAL_HOME"
}

# ==============================================================================
# APT PACKAGES
# ==============================================================================

install_system_pkgs() {

    log "Instalando pacotes APT..."
    push_indent

    try apt update

    local pkgs=(
        apt-transport-https
        build-essential
        ca-certificates
        curl
        dconf-cli
        flameshot
        git
        gnome-clocks
        gnome-shell-extension-manager
        gnome-tweaks
        gnome-weather
        gnupg
        htop
        jq
        lsb-release
        make
        nodejs
        python3-pip
        python3-venv
        remmina
        software-properties-common
        tar
        tree
        unzip
        vim
        wget
        zip
        zsh
        dbus-x11
    )

    for p in "${pkgs[@]}"; do
        log "Instalando: $p"
        try apt install -y "$p"
    done

    pop_indent
}

# ==============================================================================
# SNAP
# ==============================================================================

install_snaps() {

    if ! command -v snap >/dev/null 2>&1; then
        log "Snap não disponível."
        return
    fi

    log "Instalando Snaps..."
    push_indent

    local snaps=(
        "dbeaver-ce --classic"
        "discord"
        "postman"
    )

    for s in "${snaps[@]}"; do
        log "Snap: $s"
        try bash -c "snap install $s"
    done

    pop_indent
}

# ==============================================================================
# GOOGLE CHROME + VSCODE
# ==============================================================================

install_external_debs() {

    log "Instalando Chrome e VSCode..."
    push_indent

    local deb_dir
    deb_dir="$(mktemp -d)"

    log "Baixando Chrome..."

    try wget -q \
        -O "$deb_dir/chrome.deb" \
        https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb

    log "Baixando VSCode..."

    try wget -q \
        -O "$deb_dir/vscode.deb" \
        "https://code.visualstudio.com/sha/download?build=stable&os=linux-deb-x64"

    try apt install -y "$deb_dir"/*.deb

    rm -rf "$deb_dir"

    pop_indent
}

# ==============================================================================
# PYTHON
# ==============================================================================

setup_python() {

    log "Configurando Python..."
    push_indent

    try add-apt-repository -y ppa:deadsnakes/ppa

    try apt update

    local py_versions=(
        python3.10
        python3.12
    )

    for v in "${py_versions[@]}"; do
        log "Instalando: $v"
        try apt install -y "$v"
    done

    pop_indent
}

# ==============================================================================
# CLOUDFLARE WARP
# ==============================================================================

setup_cloudflare() {

    log "Instalando Cloudflare WARP..."
    push_indent

    try bash -c \
        "curl -fsSL https://pkg.cloudflareclient.com/pubkey.gpg \
        | gpg --yes --dearmor \
        -o /usr/share/keyrings/cloudflare-warp-archive-keyring.gpg"

    echo "deb [signed-by=/usr/share/keyrings/cloudflare-warp-archive-keyring.gpg] https://pkg.cloudflareclient.com/ $(lsb_release -cs) main" \
        > /etc/apt/sources.list.d/cloudflare-client.list

    try apt update

    try apt install -y cloudflare-warp

    try warp-cli --accept-tos registration new || true

    pop_indent
}

# ==============================================================================
# ZSH
# ==============================================================================

setup_zsh() {

    log "Configurando ZSH..."
    push_indent

    if [[ ! -d "$REAL_HOME/.oh-my-zsh" ]]; then

        log "Instalando Oh My Zsh..."

        try sudo -u "$REAL_USER" RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
            sh -c \
            "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
    fi

    if [[ -f "$REAL_HOME/.zshrc" ]]; then

        try sed -i \
            's/^ZSH_THEME=.*/ZSH_THEME="bira"/' \
            "$REAL_HOME/.zshrc"

        chown "$REAL_USER:$REAL_USER" "$REAL_HOME/.zshrc"
    fi

    local zsh_path

    zsh_path="$(which zsh)"

    if [[ -n "$zsh_path" ]]; then
        try chsh -s "$zsh_path" "$REAL_USER"
    fi

    pop_indent
}

# ==============================================================================
# GNOME
# ==============================================================================

is_gnome() {
    [[ "${XDG_CURRENT_DESKTOP:-}" =~ GNOME ]]
}

run_user_gsettings() {

    local cmd="$1"

    sudo -H -u "$REAL_USER" \
        dbus-launch bash -c "$cmd"
}

# ==============================================================================
# FONTS
# ==============================================================================

setup_gnome_fonts() {

    if ! is_gnome; then
        log "GNOME não detectado."
        return
    fi

    log "Configurando fontes..."
    push_indent

    local font_dir="$REAL_HOME/.local/share/fonts"

    mkdir -p "$font_dir"

    log "Baixando Google Sans..."

    try wget -q \
        -O "$font_dir/GoogleSans.ttf" \
        "$RAW_BASE/src/fonts/GoogleSans.ttf"

    log "Baixando Google Sans Code..."

    try wget -q \
        -O "$font_dir/GoogleSansCode.ttf" \
        "$RAW_BASE/src/fonts/GoogleSansCode.ttf"

    try chown -R "$REAL_USER:$REAL_USER" "$font_dir"

    try sudo -u "$REAL_USER" fc-cache -f

    log "Aplicando configurações GNOME..."

    try run_user_gsettings \
        "gsettings set org.gnome.desktop.interface font-name 'Google Sans 12'"

    try run_user_gsettings \
        "gsettings set org.gnome.desktop.interface document-font-name 'Google Sans 11'"

    try run_user_gsettings \
        "gsettings set org.gnome.desktop.interface monospace-font-name 'Google Sans Code 12'"

    pop_indent
}

# ==============================================================================
# WALLPAPER
# ==============================================================================

setup_wallpaper() {

    if ! is_gnome; then
        return
    fi

    log "Configurando wallpaper..."
    push_indent

    local bg="/usr/share/backgrounds/ubnt-wallpaper.jpg"

    try curl -fL \
        https://raw.githubusercontent.com/lucasoal/ubuntusetup/refs/heads/main/src/backgrounds/Fuji_san_by_amaral.png \
        -o "$bg"

    try run_user_gsettings \
        "gsettings set org.gnome.desktop.background picture-uri \"file://$bg\""

    try run_user_gsettings \
        "gsettings set org.gnome.desktop.background picture-uri-dark \"file://$bg\""

    pop_indent
}

# ==============================================================================
# CURSOR
# ==============================================================================

setup_cursor() {

    if ! is_gnome; then
        return
    fi

    log "Configurando cursor..."
    push_indent

    local zip_file="/tmp/macOSCursorWhite.zip"

    try wget -q \
        -O "$zip_file" \
        "$RAW_BASE/src/icons/macOSCursorWhite.zip"

    local extract_dir="/tmp/macos_cursor"

    rm -rf "$extract_dir"

    mkdir -p "$extract_dir"

    try unzip -o "$zip_file" -d "$extract_dir"

    local theme_name

    theme_name="$(find "$extract_dir" \
        -mindepth 1 \
        -maxdepth 1 \
        -type d \
        | head -n1 \
        | xargs basename)"

    if [[ -n "$theme_name" ]]; then

        try cp -r \
            "$extract_dir/$theme_name" \
            /usr/share/icons/

        if [[ -f "/usr/share/icons/$theme_name/index.theme" ]]; then
            try gtk-update-icon-cache \
                "/usr/share/icons/$theme_name"
        fi

        try run_user_gsettings \
            "gsettings set org.gnome.desktop.interface cursor-theme '$theme_name'"
    fi

    pop_indent
}

# ==============================================================================
# DCONF
# ==============================================================================

setup_dconf() {

    log "Aplicando dconf..."
    push_indent

    local dconf_file="/tmp/interface.dconf"

    try wget -q \
        -O "$dconf_file" \
        "$RAW_BASE/src/interface.dconf"

    try sed -i \
        "s|/<USERNAME>/|/$REAL_USER/|g" \
        "$dconf_file"

    try sudo -H -u "$REAL_USER" \
        dbus-launch dconf load / < "$dconf_file"

    pop_indent
}

# ==============================================================================
# KEYBINDINGS
# ==============================================================================

setup_keybindings() {

    if ! is_gnome; then
        return
    fi

    log "Configurando atalhos..."
    push_indent

    local kb_path="/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/"

    try run_user_gsettings \
        "gsettings set org.gnome.settings-daemon.plugins.media-keys custom-keybindings \"['$kb_path']\""

    try run_user_gsettings \
        "gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybindings:$kb_path name 'Flameshot'"

    try run_user_gsettings \
        "gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybindings:$kb_path command 'flameshot gui'"

    try run_user_gsettings \
        "gsettings set org.gnome.settings-daemon.plugins.media-keys.custom-keybindings:$kb_path binding '<Super>Print'"

    pop_indent
}

# ==============================================================================
# POSTGRESQL
# ==============================================================================

install_postgresql() {

    log "Instalando PostgreSQL..."
    push_indent

    try apt install -y postgresql postgresql-contrib

    try systemctl enable postgresql

    try systemctl start postgresql

    pop_indent
}

# ==============================================================================
# REMOVE GAMES
# ==============================================================================

remove_stock_games() {

    log "Removendo jogos..."
    push_indent

    local pkgs

    pkgs="$(dpkg --get-selections \
        | grep -Ei 'game|aisleriot|gnome-games' \
        | awk '{print $1}' \
        | xargs || true)"

    if [[ -n "${pkgs:-}" ]]; then
        try apt purge -y $pkgs
    fi

    try apt autoremove -y

    pop_indent
}

# ==============================================================================
# CLEANUP
# ==============================================================================

att_and_cleanup() {

    log "Atualizando sistema..."
    push_indent

    try apt update

    try apt upgrade -y

    try apt autoremove -y

    try apt autoclean -y

    pop_indent
}

# ==============================================================================
# MAIN
# ==============================================================================

main() {

    check_user_permissions

    log "INICIANDO SETUP UBUNTU"

    remove_stock_games
    install_system_pkgs
    install_snaps
    install_external_debs
    setup_python
    setup_zsh
    setup_gnome_fonts
    setup_wallpaper
    setup_cursor
    setup_dconf
    setup_cloudflare
    # setup_keybindings

    # install_postgresql

    att_and_cleanup

    success "SETUP FINALIZADO"

    echo
    echo "Log salvo em:"
    echo "$LOG_FILE"
    echo

    read -rp "Deseja reiniciar agora? [y/N] " resp

    if [[ "$resp" =~ ^([yY][eE][sS]|[yY])$ ]]; then
        reboot
    fi
}

main "$@"