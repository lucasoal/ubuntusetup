#!/usr/bin/env bash

set -uo pipefail

# =========================================================
# MY GNOME SETUP - UBUNTU 24.04
# Version 2
# =========================================================

YELLOW='\033[1;33m'
GREEN='\033[1;32m'
RED='\033[1;31m'
NC='\033[0m'

REPO_URL="https://github.com/lucasoal/ubntsetup.git"
TEMP_DIR="/tmp/ubntsetup"

LOG_FILE="/tmp/ubntsetup_$(date +%F_%H-%M-%S).log"

INDENT=""
OLD_INDENTS=()

# =========================================================
# LOGGING
# =========================================================

log() {
    echo -e "${INDENT}${YELLOW}[$(date '+%H:%M:%S')] $1${NC}" | tee -a "$LOG_FILE"
}

success() {
    echo -e "${INDENT}${GREEN}[$(date '+%H:%M:%S')] $1${NC}" | tee -a "$LOG_FILE"
}

error() {
    echo -e "${INDENT}${RED}[$(date '+%H:%M:%S')] $1${NC}" | tee -a "$LOG_FILE"
}

try() {
    local OLD_INDENT_TRY="$INDENT"

    INDENT="$INDENT  "

    if "$@"; then
        INDENT="$OLD_INDENT_TRY"
        return 0
    else
        error "FALHA: $*"
        INDENT="$OLD_INDENT_TRY"
        return 1
    fi
}

push_indent() {
    OLD_INDENTS+=("$INDENT")
    INDENT="$INDENT  "
}

pop_indent() {
    INDENT="${OLD_INDENTS[-1]}"
    unset 'OLD_INDENTS[${#OLD_INDENTS[@]}-1]'
}

# =========================================================
# CHECKS
# =========================================================

check_root() {
    if [[ $EUID -ne 0 ]]; then
        error "Este script deve ser executado com sudo."
        echo
        echo "Use:"
        echo "curl -fsSL https://raw.githubusercontent.com/lucasoal/ubntsetup/main/install | sudo bash"
        exit 1
    fi
}

detect_real_user() {
    REAL_USER="${SUDO_USER:-$(logname)}"
    REAL_HOME=$(getent passwd "$REAL_USER" | cut -d: -f6)

    log "Usuário detectado: $REAL_USER"
    log "Home detectada: $REAL_HOME"
}

# =========================================================
# DEPENDENCIES
# =========================================================

install_dependencies() {
    log "Instalando dependências..."
    push_indent

    try apt update -y

    try apt install -y \
        git \
        curl \
        unzip \
        zsh \
        dconf-cli \
        gnome-shell-extension-manager

    pop_indent
}

# =========================================================
# DOWNLOAD REPOSITORY
# =========================================================

download_repository() {
    log "Baixando repositório..."
    push_indent

    rm -rf "$TEMP_DIR"

    try git clone "$REPO_URL" "$TEMP_DIR"

    BASE_DIR="$TEMP_DIR"

    success "Repositório clonado em $BASE_DIR"

    pop_indent
}

# =========================================================
# OH MY ZSH
# =========================================================

setup_zsh() {
    log "Configurando ZSH..."
    push_indent

    if [ ! -d "$REAL_HOME/.oh-my-zsh" ]; then
        log "Instalando Oh My Zsh..."

        try sudo -u "$REAL_USER" RUNZSH=no CHSH=no sh -c \
            "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"

    else
        log "Oh My Zsh já instalado."
    fi

    if [ -f "$REAL_HOME/.zshrc" ]; then
        log "Definindo tema bira..."

        try sed -i 's/^ZSH_THEME=.*/ZSH_THEME="bira"/' "$REAL_HOME/.zshrc"

        chown "$REAL_USER:$REAL_USER" "$REAL_HOME/.zshrc"
    fi

    local zsh_path
    zsh_path=$(which zsh)

    if [ -n "$zsh_path" ]; then
        log "Definindo ZSH como shell padrão..."
        try chsh -s "$zsh_path" "$REAL_USER"
    fi

    pop_indent
}

# =========================================================
# FONTS
# =========================================================

install_fonts() {
    log "Instalando fontes..."
    push_indent

    local fonts_dir="$REAL_HOME/.local/share/fonts"

    mkdir -p "$fonts_dir"

    try cp "$BASE_DIR/src/fonts/"* "$fonts_dir/"

    try chown -R "$REAL_USER:$REAL_USER" "$fonts_dir"

    try sudo -u "$REAL_USER" fc-cache -f

    try sudo -u "$REAL_USER" dbus-run-session gsettings set \
        org.gnome.desktop.interface font-name 'GoogleSans 12'

    try sudo -u "$REAL_USER" dbus-run-session gsettings set \
        org.gnome.desktop.interface document-font-name 'GoogleSans 11'

    try sudo -u "$REAL_USER" dbus-run-session gsettings set \
        org.gnome.desktop.interface monospace-font-name 'GoogleSansCode 12'

    pop_indent
}

# =========================================================
# WALLPAPER
# =========================================================

setup_wallpaper() {
    log "Configurando wallpaper..."
    push_indent

    local bg_url="https://wallpapercave.com/wp/wp10824773.jpg"
    local bg_dest="/usr/share/backgrounds/Catalina-4.jpg"

    mkdir -p "/usr/share/backgrounds"

    try curl -fL "$bg_url" -o "$bg_dest"

    try sudo -u "$REAL_USER" dbus-run-session gsettings set \
        org.gnome.desktop.background picture-uri \
        "file://$bg_dest"

    try sudo -u "$REAL_USER" dbus-run-session gsettings set \
        org.gnome.desktop.background picture-uri-dark \
        "file://$bg_dest"

    pop_indent
}

# =========================================================
# CURSOR
# =========================================================

install_cursor() {
    log "Instalando cursor..."
    push_indent

    local cursor_zip="$BASE_DIR/src/icons/macOSCursorWhite.zip"
    local cursor_tmp="/tmp/macos_cursor"
    local cursor_dest="/usr/share/icons"

    rm -rf "$cursor_tmp"

    mkdir -p "$cursor_tmp"

    try unzip -o "$cursor_zip" -d "$cursor_tmp"

    try cp -r "$cursor_tmp"/* "$cursor_dest/"

    local cursor_name
    cursor_name=$(find "$cursor_tmp" -mindepth 1 -maxdepth 1 -type d | head -n 1 | xargs basename)

    if [ -n "$cursor_name" ]; then
        log "Aplicando cursor: $cursor_name"

        try sudo -u "$REAL_USER" dbus-run-session gsettings set \
            org.gnome.desktop.interface cursor-theme \
            "$cursor_name"
    fi

    pop_indent
}

# =========================================================
# DCONF
# =========================================================

apply_dconf() {
    log "Aplicando configurações do GNOME..."
    push_indent

    local dconf_file="$BASE_DIR/src/interface.dconf"

    sed -i "s|/<USERNAME>/|/$REAL_USER/|g" "$dconf_file"

    try sudo -u "$REAL_USER" dbus-run-session dconf load / < "$dconf_file"

    pop_indent
}

# =========================================================
# CLEANUP
# =========================================================

cleanup_system() {
    log "Limpando sistema..."
    push_indent

    try apt autoremove -y
    try apt autoclean -y

    pop_indent
}

cleanup_temp() {
    log "Removendo arquivos temporários..."
    push_indent

    try rm -rf "$TEMP_DIR"

    pop_indent
}

# =========================================================
# MAIN
# =========================================================

main() {
    check_root
    detect_real_user

    log "INICIANDO SETUP UBUNTU 24.04"

    install_dependencies
    download_repository
    setup_zsh
    install_fonts
    setup_wallpaper
    install_cursor
    apply_dconf
    cleanup_system
    cleanup_temp

    success "SETUP FINALIZADO COM SUCESSO"

    echo
    read -rp "Deseja reiniciar agora? [y/N]: " resp

    if [[ "$resp" =~ ^([yY][eE][sS]|[yY])$ ]]; then
        reboot
    fi
}

main "$@"